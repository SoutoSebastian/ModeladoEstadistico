library(ggplot2)
library(tidyverse)
library(MASS)
refugio <- read_csv("refugio.csv")
cat("Cantidad de animales:", nrow(refugio))
refugio %>%
count(desenlace) %>%
mutate(
porcentaje = round(100 * n / sum(n), 2)
) %>%
ggplot(aes(x = reorder(desenlace, -n), y = n)) +
geom_col(fill = "steelblue") +
geom_text(aes(label = paste0(porcentaje, "%")),
vjust = -0.3) +
labs(
title = "Distribución de desenlaces",
x = "Desenlace",
y = "Cantidad de animales"
) +
theme_minimal()
summary(refugio)
glimpse(refugio)
refugio %>%
count(sexo) %>%
ggplot(aes(x = sexo, y = n, fill = sexo)) +
geom_col() +
geom_text(aes(label = n),
vjust = -0.3) +
labs(
x = "Sexo",
y = "Cantidad de animales"
) +
theme_minimal() +
theme(
plot.title = element_text(face = "bold"),
legend.position = "none"
)
refugio %>%
ggplot(aes(x = sexo,
fill = factor(dog))) +
geom_bar(position = "dodge") +
labs(
x = "Sexo",
y = "Cantidad",
fill = "Perros vs Gatos"
) +
scale_fill_manual(
values = c("0" = "tomato",
"1" = "steelblue"),
labels = c("Perro", "Gato")
) +
theme_minimal()
ggplot(refugio, aes(x = age_years)) +
geom_histogram(bins = 30,
fill = "steelblue",
color = "black") +
labs(
title = "Distribucion de edades",
x = "Edad",
y = "Cantidad de animales"
) +
theme_minimal()
ggplot(refugio,
aes(x = age_years)) +
geom_histogram(aes(y = after_stat(density)),
fill = "steelblue",
color = "black",
bins = 30) +
facet_wrap(~animal_type) +
labs(
x = "Edad",
y = "Densidad"
) +
theme_minimal()
ggplot(refugio,
aes(x = desenlace,
fill = factor(sterilized))) +
geom_bar(position = "fill") +
labs(
x = "Desenlace",
y = "Proporción",
fill = "Esterilizado"
)
ggplot(refugio, aes(x = los)) +
geom_histogram(
aes(y = after_stat(density)),
bins = 50,
fill = "lightblue",
color = "white"
) +
geom_density(
linewidth = 1
) +
coord_cartesian(xlim = c(0, 100)) +
labs(
title = "Distribucion del tiempo de estadia en el refugio",
subtitle = "Histograma y curva de densidad",
x = "Tiempo de estadia (dias)",
y = "Densidad"
) +
theme_minimal(base_size = 12) +
theme(
plot.title = element_text(face = "bold")
)
ggplot(refugio,
aes(x = desenlace,
y = los)) +
geom_boxplot(
fill = "lightblue"
) +
labs (
title = "Dias de estadia por desenlace",
y = "Tiempo de estadia",
x = "Desenlace"
)
tasa_verdadera <- refugio %>%
group_by(breed_main) %>%
summarise(
n = n(),
adoptados = sum(desenlace == "Adopcion")
) %>%
filter(n >= 100) %>%
mutate(
tasa_verdadera = adoptados / n
) %>%
arrange(desc(n))
head(tasa_verdadera)
set.seed(123)
muestra <- refugio %>%
filter(breed_main %in% tasa_verdadera$breed_main) %>%
group_by(breed_main) %>%
slice_sample(n = 15)
tasa_cruda <- muestra %>%
group_by(breed_main) %>%
summarise(
adopciones = sum(desenlace == "Adopcion"),
tasa_cruda = adopciones / 15
)
comparacion <- tasa_verdadera %>%
dplyr::select(breed_main, tasa_verdadera) %>%
left_join(tasa_cruda, by = "breed_main")
head(comparacion)
ggplot(comparacion,
aes(x = tasa_verdadera,
y = tasa_cruda)) +
geom_point() +
geom_abline(slope = 1,
intercept = 0,
color = "red")
comparacion <- comparacion %>%
mutate(
tasa_cruda_ajustada = pmin(pmax(tasa_cruda, 0.001), 0.999)
)
fit_beta <- fitdistr(
comparacion$tasa_cruda_ajustada,
densfun = "beta",
start = list(shape1 = 10, shape2 = 10)
)
fit_beta
alpha_0 <- fit_beta$estimate["shape1"]
beta_0 <- fit_beta$estimate["shape2"]
alpha_0
beta_0
m <- 15
comparacion <- comparacion %>%
mutate(
tasa_eb = (alpha_0 + adopciones) / (alpha_0 + beta_0 + m)
)
head(comparacion)
